            "[('ID', 'ITEM'), ('OP', '+'), ('ID', 'ITEM'), ('OP', '-'), ('ID', 'DISCOUNT')]\n"
          ]
        }
      ],
      "source": [
        "def tokenize(expr):\n",
        "    tokens = []\n",
        "    for t in expr.split():\n",
        "        if t.isalpha():\n",
        "            tokens.append((\"ID\", t))\n",
        "        else:\n",
        "            tokens.append((\"OP\", t))\n",
        "    return tokens\n",
        "print(tokenize(\"ITEM + ITEM - DISCOUNT\"))"
      ]
    }
  ]
}